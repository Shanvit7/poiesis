{
  "name": "@poiesis/extension",
  "displayName": "Poiesis",
  "version": "0.0.1",
  "description": "Remember what you actually learn on YouTube",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "postbuild": "node scripts/fix-build.mjs",
    "fix": "node scripts/fix-build.mjs",
    "lint": "biome check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/google": "^4.0.17",
    "@ai-sdk/openai": "^4.0.15",
    "@radix-ui/react-slot": "^1.3.0",
    "ai": "^7.0.29",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "loglevel": "^1.9.2",
    "lucide-react": "^1.24.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supermemory": "3.14.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "valibot": "^1.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@types/chrome": "^0.0.308",
    "@types/dom-chromium-ai": "^0.0.10",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5.8.3"
  },
  "manifest": {
    "host_permissions": [
      "https://www.youtube.com/*",
      "https://api.supermemory.ai/*",
      "https://generativelanguage.googleapis.com/*",
      "https://api.openai.com/*",
      "https://api.anthropic.com/*"
    ],
    "permissions": ["storage", "tabs", "activeTab", "sidePanel"]
  }
}
