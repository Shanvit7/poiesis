{
  "name": "@shanvit7/poiesis",
  "version": "0.1.0",
  "description": "Pi extension — YouTube tutorial tutor. Ingest any coding video, grill the user, scaffold the project, and generate chapter-by-chapter lab guides.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "poiesis",
    "tutor",
    "youtube",
    "coding-tutorial"
  ],
  "author": "shanvit7",
  "license": "MIT",
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "eval": "promptfoo eval",
    "eval:view": "promptfoo view",
    "eval:ci": "promptfoo eval --ci --no-cache"
  },
  "files": ["index.ts", "src", "prompts", "skills", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": ["./index.ts", "node_modules/@juicesharp/rpiv-ask-user-question/index.ts"],
    "skills": ["./skills"]
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@juicesharp/rpiv-ask-user-question": "*"
  },
  "bundledDependencies": ["@juicesharp/rpiv-ask-user-question"],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "promptfoo": "^0.121.19",
    "typescript": "^7.0.2"
  }
}
